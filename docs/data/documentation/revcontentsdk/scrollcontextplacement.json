{"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/revcontentsdk\/scrollcontextplacement"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/revcontentsdk\/scrollcontextplacement"]}],"identifier":{"url":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/ScrollContextPlacement","interfaceLanguage":"swift"},"topicSections":[{"anchor":"Related-modifiers","title":"Related modifiers","identifiers":["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/SwiftUICore\/View\/revcontentScrollContext()","doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/RevcontentAdView"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"API Collection","modules":[{"name":"RevcontentSDK"}],"role":"collectionGroup","title":"Scroll context placement"},"hierarchy":{"paths":[["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK"]]},"kind":"article","seeAlsoSections":[{"anchor":"Articles","title":"Articles","identifiers":["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/ThemeIntegration","doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/JSEventContract"],"generated":true}],"abstract":[{"text":"Apply ","type":"text"},{"type":"codeVoice","code":"revcontentScrollContext()"},{"text":" inside the ","type":"text"},{"type":"codeVoice","code":"ScrollView"},{"text":"’s content, not on the ","type":"text"},{"type":"codeVoice","code":"ScrollView"},{"text":" itself.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"codeVoice","code":"RevcontentAdView"},{"type":"text","text":" reports widget visibility back to the underlying widget JavaScript so impressions, viewability, and intersection events fire correctly. To do that, the SDK needs a reference to the enclosing "},{"type":"codeVoice","code":"UIScrollView"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/SwiftUICore\/View\/revcontentScrollContext()"},{"type":"text","text":" modifier walks the view hierarchy at attach time to find that scroll view. It must be applied to a view that is "},{"type":"emphasis","inlineContent":[{"text":"inside","type":"text"}]},{"type":"text","text":" the "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":"’s content — not to the "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":" itself, where it would walk the hierarchy "},{"type":"emphasis","inlineContent":[{"type":"text","text":"above"}]},{"type":"text","text":" the scroll view and miss it."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Misplace the modifier and the SDK’s DEBUG assertions will fire immediately during development. In release, the SDK falls back to a warning and impression data will be missing or inaccurate."}],"type":"paragraph"},{"anchor":"Right-way","level":2,"type":"heading","text":"Right way"},{"inlineContent":[{"text":"Apply the modifier to a view inside the ","type":"text"},{"type":"codeVoice","code":"ScrollView"},{"text":"’s content:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["ScrollView {","    VStack {","        ArticleBody()","        RevcontentAdView(widgetId: \"abc-123\")","    }","    .revcontentScrollContext()","}"]},{"inlineContent":[{"type":"text","text":"The modifier is on the "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":", which is inside the "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":". The finder walks up from the "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" and discovers the enclosing "},{"type":"codeVoice","code":"UIScrollView"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Wrong-way","level":2,"type":"heading","text":"Wrong way"},{"inlineContent":[{"type":"text","text":"Do not apply the modifier to the "},{"code":"ScrollView","type":"codeVoice"},{"type":"text","text":" itself:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ WRONG — finder walks above the ScrollView and finds nothing","ScrollView {","    VStack {","        ArticleBody()","        RevcontentAdView(widgetId: \"abc-123\")","    }","}",".revcontentScrollContext()"]},{"inlineContent":[{"text":"Also wrong: forgetting the modifier entirely. The SDK provides a default empty scroll context as a fallback, so ","type":"text"},{"code":"RevcontentAdView","type":"codeVoice"},{"text":" will still render — but no scroll-driven events will fire, and DEBUG builds will assert.","type":"text"}],"type":"paragraph"},{"anchor":"Why-this-design","level":2,"type":"heading","text":"Why this design"},{"inlineContent":[{"type":"text","text":"SwiftUI doesn’t expose the underlying "},{"type":"codeVoice","code":"UIScrollView"},{"type":"text","text":" directly. The modifier installs a tiny invisible "},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" as a background, then walks up the superview chain at window-attachment time to locate the scroll view. Apply it inside the "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":"’s content for that walk to succeed."}],"type":"paragraph"}]}],"references":{"doc://com.revcontent.RevcontentSDK/documentation/RevcontentSDK/ThemeIntegration":{"kind":"article","type":"topic","abstract":[{"text":"Coordinate the widget’s appearance with your app’s color scheme.","type":"text"}],"title":"Theme integration","url":"\/documentation\/revcontentsdk\/themeintegration","identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/ThemeIntegration","role":"collectionGroup"},"doc://com.revcontent.RevcontentSDK/documentation/RevcontentSDK":{"abstract":[{"text":"Native SwiftUI integration for Revcontent ad widgets.","type":"text"}],"identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK","type":"topic","url":"\/documentation\/revcontentsdk","title":"RevcontentSDK","role":"collection","kind":"symbol"},"doc://com.revcontent.RevcontentSDK/documentation/RevcontentSDK/JSEventContract":{"kind":"article","type":"topic","title":"JavaScript event contract","url":"\/documentation\/revcontentsdk\/jseventcontract","abstract":[{"text":"Events the SDK dispatches into the embedded widget, for widget JavaScript to consume.","type":"text"}],"identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/JSEventContract","role":"article"},"doc://com.revcontent.RevcontentSDK/documentation/RevcontentSDK/RevcontentAdView":{"role":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"RevcontentAdView"}],"abstract":[{"text":"A SwiftUI view that displays a Revcontent ad widget.","type":"text"}],"url":"\/documentation\/revcontentsdk\/revcontentadview","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RevcontentAdView"}],"title":"RevcontentAdView","kind":"symbol","identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/RevcontentAdView"},"doc://com.revcontent.RevcontentSDK/documentation/RevcontentSDK/SwiftUICore/View/revcontentScrollContext()":{"kind":"symbol","abstract":[{"text":"Marks this view’s enclosing ","type":"text"},{"type":"codeVoice","code":"ScrollView"},{"text":" as the scroll context for any","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"RevcontentAdView"},{"text":" descendants.","type":"text"}],"identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/SwiftUICore\/View\/revcontentScrollContext()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"revcontentScrollContext"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:7SwiftUI4ViewP"}],"url":"\/documentation\/revcontentsdk\/swiftuicore\/view\/revcontentscrollcontext()","role":"symbol","conformance":{"conformancePrefix":[{"type":"text","text":"Conforms when"}],"constraints":[{"type":"codeVoice","code":"Self"},{"type":"text","text":" is "},{"type":"codeVoice","code":"View"},{"type":"text","text":"."}],"availabilityPrefix":[{"type":"text","text":"Available when"}]},"title":"revcontentScrollContext()","type":"topic"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"value":"occ","op":"replace","path":"\/identifier\/interfaceLanguage"},{"path":"\/topicSections","value":null,"op":"replace"},{"path":"\/seeAlsoSections","value":[{"anchor":"Articles","title":"Articles","identifiers":["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/ThemeIntegration","doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/JSEventContract"],"generated":true}],"op":"replace"}]}]}