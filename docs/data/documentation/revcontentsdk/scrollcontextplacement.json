{"metadata":{"role":"collectionGroup","title":"Scroll context placement","roleHeading":"API Collection","modules":[{"name":"RevcontentSDK"}]},"identifier":{"url":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/ScrollContextPlacement","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Apply "},{"code":"revcontentScrollContext()","type":"codeVoice"},{"type":"text","text":" inside the "},{"code":"ScrollView","type":"codeVoice"},{"type":"text","text":"’s content, not on the "},{"code":"ScrollView","type":"codeVoice"},{"type":"text","text":" itself."}],"seeAlsoSections":[{"generated":true,"title":"Articles","anchor":"Articles","identifiers":["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/ThemeIntegration","doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/JSEventContract"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","hierarchy":{"paths":[["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/revcontentsdk\/scrollcontextplacement"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/revcontentsdk\/scrollcontextplacement"]}],"topicSections":[{"title":"Related modifiers","anchor":"Related-modifiers","identifiers":["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/SwiftUICore\/View\/revcontentScrollContext()","doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/RevcontentAdView"]}],"sections":[],"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"codeVoice","code":"RevcontentAdView"},{"type":"text","text":" reports widget visibility back to the underlying widget JavaScript so impressions, viewability, and intersection events fire correctly. To do that, the SDK needs a reference to the enclosing "},{"type":"codeVoice","code":"UIScrollView"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/SwiftUICore\/View\/revcontentScrollContext()","type":"reference","isActive":true},{"type":"text","text":" modifier walks the view hierarchy at attach time to find that scroll view. It must be applied to a view that is "},{"inlineContent":[{"text":"inside","type":"text"}],"type":"emphasis"},{"type":"text","text":" the "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":"’s content — not to the "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":" itself, where it would walk the hierarchy "},{"inlineContent":[{"type":"text","text":"above"}],"type":"emphasis"},{"type":"text","text":" the scroll view and miss it."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Misplace the modifier and the SDK’s DEBUG assertions will fire immediately during development. In release, the SDK falls back to a warning and impression data will be missing or inaccurate."}],"type":"paragraph"},{"anchor":"Right-way","type":"heading","text":"Right way","level":2},{"inlineContent":[{"text":"Apply the modifier to a view inside the ","type":"text"},{"code":"ScrollView","type":"codeVoice"},{"text":"’s content:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["ScrollView {","    VStack {","        ArticleBody()","        RevcontentAdView(widgetId: \"abc-123\")","    }","    .revcontentScrollContext()","}"]},{"inlineContent":[{"type":"text","text":"The modifier is on the "},{"code":"VStack","type":"codeVoice"},{"type":"text","text":", which is inside the "},{"code":"ScrollView","type":"codeVoice"},{"type":"text","text":". The finder walks up from the "},{"code":"VStack","type":"codeVoice"},{"type":"text","text":" and discovers the enclosing "},{"code":"UIScrollView","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Wrong-way","type":"heading","text":"Wrong way","level":2},{"inlineContent":[{"text":"Do not apply the modifier to the ","type":"text"},{"type":"codeVoice","code":"ScrollView"},{"text":" itself:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ WRONG — finder walks above the ScrollView and finds nothing","ScrollView {","    VStack {","        ArticleBody()","        RevcontentAdView(widgetId: \"abc-123\")","    }","}",".revcontentScrollContext()"]},{"inlineContent":[{"type":"text","text":"Also wrong: forgetting the modifier entirely. The SDK provides a default empty scroll context as a fallback, so "},{"type":"codeVoice","code":"RevcontentAdView"},{"type":"text","text":" will still render — but no scroll-driven events will fire, and DEBUG builds will assert."}],"type":"paragraph"},{"anchor":"Why-this-design","type":"heading","text":"Why this design","level":2},{"inlineContent":[{"type":"text","text":"SwiftUI doesn’t expose the underlying "},{"code":"UIScrollView","type":"codeVoice"},{"type":"text","text":" directly. The modifier installs a tiny invisible "},{"code":"UIView","type":"codeVoice"},{"type":"text","text":" as a background, then walks up the superview chain at window-attachment time to locate the scroll view. Apply it inside the "},{"code":"ScrollView","type":"codeVoice"},{"type":"text","text":"’s content for that walk to succeed."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://com.revcontent.RevcontentSDK/documentation/RevcontentSDK/ThemeIntegration":{"identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/ThemeIntegration","role":"collectionGroup","abstract":[{"type":"text","text":"Coordinate the widget’s appearance with your app’s color scheme."}],"kind":"article","type":"topic","title":"Theme integration","url":"\/documentation\/revcontentsdk\/themeintegration"},"doc://com.revcontent.RevcontentSDK/documentation/RevcontentSDK":{"url":"\/documentation\/revcontentsdk","identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK","type":"topic","kind":"symbol","abstract":[{"text":"Native SwiftUI integration for Revcontent ad widgets.","type":"text"}],"title":"RevcontentSDK","role":"collection"},"doc://com.revcontent.RevcontentSDK/documentation/RevcontentSDK/RevcontentAdView":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RevcontentAdView","kind":"identifier"}],"identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/RevcontentAdView","type":"topic","title":"RevcontentAdView","kind":"symbol","navigatorTitle":[{"text":"RevcontentAdView","kind":"identifier"}],"abstract":[{"type":"text","text":"A SwiftUI view that displays a Revcontent ad widget."}],"url":"\/documentation\/revcontentsdk\/revcontentadview","role":"symbol"},"doc://com.revcontent.RevcontentSDK/documentation/RevcontentSDK/JSEventContract":{"type":"topic","role":"article","identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/JSEventContract","kind":"article","abstract":[{"type":"text","text":"Events the SDK dispatches into the embedded widget, for widget JavaScript to consume."}],"title":"JavaScript event contract","url":"\/documentation\/revcontentsdk\/jseventcontract"},"doc://com.revcontent.RevcontentSDK/documentation/RevcontentSDK/SwiftUICore/View/revcontentScrollContext()":{"conformance":{"conformancePrefix":[{"text":"Conforms when","type":"text"}],"availabilityPrefix":[{"text":"Available when","type":"text"}],"constraints":[{"code":"Self","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"View","type":"codeVoice"},{"text":".","type":"text"}]},"title":"revcontentScrollContext()","role":"symbol","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"revcontentScrollContext","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}],"identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/SwiftUICore\/View\/revcontentScrollContext()","kind":"symbol","url":"\/documentation\/revcontentsdk\/swiftuicore\/view\/revcontentscrollcontext()","abstract":[{"text":"Marks this view’s enclosing ","type":"text"},{"code":"ScrollView","type":"codeVoice"},{"text":" as the scroll context for any","type":"text"},{"text":" ","type":"text"},{"code":"RevcontentAdView","type":"codeVoice"},{"text":" descendants.","type":"text"}]}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"op":"replace","value":"occ","path":"\/identifier\/interfaceLanguage"},{"op":"replace","value":null,"path":"\/topicSections"},{"op":"replace","value":[{"title":"Articles","generated":true,"identifiers":["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/ThemeIntegration","doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/JSEventContract"],"anchor":"Articles"}],"path":"\/seeAlsoSections"}]}]}