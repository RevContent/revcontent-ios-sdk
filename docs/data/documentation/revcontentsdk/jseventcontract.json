{"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"RevcontentSDK communicates with the widget’s JavaScript by dispatching "},{"type":"codeVoice","code":"CustomEvent"},{"type":"text","text":" instances on "},{"type":"codeVoice","code":"document"},{"type":"text","text":". Each event is dispatched with "},{"type":"codeVoice","code":"bubbles: true, cancelable: true"},{"type":"text","text":", and the payload is on "},{"type":"codeVoice","code":"event.detail"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"Widgets that want to participate in scroll-driven impression tracking or react to theme changes should add event listeners to ","type":"text"},{"code":"document","type":"codeVoice"},{"text":" during their initialization.","type":"text"}]},{"level":2,"text":"`revcontent:scroll`","type":"heading","anchor":"revcontentscroll"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Dispatched on every scroll update from the host "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":", throttled to ~30Hz with trailing coalescing. Also fired once immediately after the widget finishes loading, so the widget has initial geometry without waiting for the first scroll."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Payload (","type":"text"},{"code":"event.detail","type":"codeVoice"},{"text":"):","type":"text"}],"type":"strong"}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Key"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"rawOffset"}]}],[{"type":"paragraph","inlineContent":[{"code":"Number","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"The host scroll 