{"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"text":"RevcontentSDK bridges SwiftUI’s color scheme into the embedded widget via two channels:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"The underlying ","type":"text"},{"code":"WKWebView","type":"codeVoice"},{"text":"’s ","type":"text"},{"code":"overrideUserInterfaceStyle","type":"codeVoice"},{"text":", so any CSS using ","type":"text"},{"code":"@media (prefers-color-scheme: dark)","type":"codeVoice"},{"text":" resolves correctly.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"revcontent:theme"},{"text":" JavaScript event dispatched to the widget on change, so widget code can react explicitly.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"type":"text","text":"Both fire whenever the resolved SwiftUI color scheme changes — at first load and on every subsequent toggle."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Letting the widget inherit the system scheme","anchor":"Letting-the-widget-inherit-the-system-scheme"},{"inlineContent":[{"type":"text","text":"By default, "},{"type":"codeVoice","code":"RevcontentAdView"},{"type":"text","text":" inherits the color scheme from the SwiftUI environment, which is driven by the user’s system setting. No extra code required:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["RevcontentAdView(widgetId: \"abc-123\")"]},{"inlineContent":[{"text":"If the user toggles dark mode in Settings, the widget receives a ","type":"text"},{"code":"revcontent:theme","type":"codeVoice"},{"text":" event and its ","type":"text"},{"code":"overrideUserInterfaceStyle","type":"codeVoice"},{"text":" updates accordingly.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Forcing a specific scheme","anchor":"Forcing-a-specific-scheme"},{"inlineContent":[{"text":"Override the color scheme with the dedicated modifier:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["RevcontentAdView(widgetId: \"abc-123\")","    .revcontentColorScheme(.dark)"]},{"inlineContent":[{"type":"text","text":"This is equivalent to "},{"code":".environment(\\.colorScheme, .dark)","type":"codeVoice"},{"type":"text","text":" but reads more clearly. Use it when you want the widget pinned to a specific appearance regardless of system setting — for example, inside an in-app reader that’s always dark."}],"type":"paragraph"},{"inlineContent":[{"text":"You can also use SwiftUI’s built-in ","type":"text"},{"code":".preferredColorScheme(_:)","type":"codeVoice"},{"text":" higher up the view tree to set the scheme app-wide; the widget will follow.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"What the widget should do","anchor":"What-the-widget-should-do"},{"inlineContent":[{"text":"The widget’s CSS and JavaScript should respect both bridge channels:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"CSS"}]},{"type":"text","text":": use "},{"code":"@media (prefers-color-scheme: dark) { ... }","type":"codeVoice"},{"type":"text","text":" for dark-mode styles. The SDK’s "},{"code":"overrideUserInterfaceStyle","type":"codeVoice"},{"type":"text","text":" ensures this resolves correctly inside the "},{"code":"WKWebView","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"JavaScript"}],"type":"strong"},{"text":": optionally listen for ","type":"text"},{"code":"revcontent:theme","type":"codeVoice"},{"text":" events on ","type":"text"},{"code":"document","type":"codeVoice"},{"text":" if the widget needs to react imperatively. See ","type":"text"},{"identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/JSEventContract","isActive":true,"type":"reference"},{"text":" for the payload shape.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/ThemeIntegration"},"abstract":[{"type":"text","text":"Coordinate the widget’s appearance with your app’s color scheme."}],"variants":[{"paths":["\/documentation\/revcontentsdk\/themeintegration"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/revcontentsdk\/themeintegration"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"article","metadata":{"role":"collectionGroup","roleHeading":"API Collection","title":"Theme integration","modules":[{"name":"RevcontentSDK"}]},"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"topicSections":[{"anchor":"Related","identifiers":["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/SwiftUICore\/View\/revcontentColorScheme(_:)","doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/JSEventContract"],"title":"Related"}],"seeAlsoSections":[{"generated":true,"anchor":"Articles","identifiers":["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/ScrollContextPlacement","doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/JSEventContract"],"title":"Articles"}],"hierarchy":{"paths":[["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK"]]},"references":{"doc://com.revcontent.RevcontentSDK/documentation/RevcontentSDK/JSEventContract":{"kind":"article","type":"topic","title":"JavaScript event contract","url":"\/documentation\/revcontentsdk\/jseventcontract","abstract":[{"text":"Events the SDK dispatches into the embedded widget, for widget JavaScript to consume.","type":"text"}],"identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/JSEventContract","role":"article"},"doc://com.revcontent.Revcont