{"abstract":[{"text":"Coordinate the widget’s appearance with your app’s color scheme.","type":"text"}],"seeAlsoSections":[{"identifiers":["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/ScrollContextPlacement","doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/JSEventContract"],"title":"Articles","generated":true,"anchor":"Articles"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/ThemeIntegration"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"RevcontentSDK bridges SwiftUI’s color scheme into the embedded widget via two channels:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"The underlying "},{"type":"codeVoice","code":"WKWebView"},{"type":"text","text":"’s "},{"type":"codeVoice","code":"overrideUserInterfaceStyle"},{"type":"text","text":", so any CSS using "},{"type":"codeVoice","code":"@media (prefers-color-scheme: dark)"},{"type":"text","text":" resolves correctly."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"code":"revcontent:theme","type":"codeVoice"},{"text":" JavaScript event dispatched to the widget on change, so widget code can react explicitly.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Both fire whenever the resolved SwiftUI color scheme changes — at first load and on every subsequent toggle.","type":"text"}]},{"type":"heading","anchor":"Letting-the-widget-inherit-the-system-scheme","level":2,"text":"Letting the widget inherit the system scheme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, "},{"code":"RevcontentAdView","t