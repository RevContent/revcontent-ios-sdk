{"abstract":[{"text":"Applies explore-more interception to this view.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"revcontentExploreMore"},{"kind":"text","text":"("},{"kind":"externalParam","text":"config"},{"kind":"text","text":": "},{"identifier":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/ExploreMoreConfig","kind":"typeIdentifier","text":"ExploreMoreConfig","preciseIdentifier":"s:13RevcontentSDK17ExploreMoreConfigV"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:7SwiftUI4ViewP"},{"kind":"text","text":"\n"}],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When applied to an article view inside a "},{"type":"codeVoice","code":"NavigationStack"},{"type":"text","text":", this modifier"},{"type":"text","text":" "},{"type":"text","text":"replaces the system back button with a custom one. When the user taps it,"},{"type":"text","text":" "},{"type":"text","text":"the SDK checks the configured frequency capping; if it should show, a sheet"},{"type":"text","text":" "},{"type":"text","text":"is presented with the configured widget. Dismissing the sheet completes"},{"type":"text","text":" "},{"type":"text","text":"the original back navigation."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the SDK is not configured ("},{"type":"codeVoice","code":"Revcontent.configure(...)"},{"type":"text","text":" hasn’t been called),"},{"type":"text","text":" "},{"type":"text","text":"this modifier is a no-op and the system back button behaves normally."}]},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"type":"codeListing","code":["NavigationStack {","    ArticleListView()","        .navigationDestination(for: Article.self) { article in","            ArticleDetailView(article: article)","                .revcontentExploreMore(config: ExploreMoreConfig(","                    widgetId: \"explore-more-widget-id\",","                    frequencyCapping: .oncePerSession","                ))","        }","}"],"syntax":"swift"}]}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK","doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/RevcontentAdView"]]},"variants":[{"paths":["\/documentation\/revcontentsdk\/revcontentadview\/revcontentexploremore(config:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","metadata":{"title":"revcontentExploreMore(config:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"revcontentExploreMore","kind":"identifier"},{"text":"(","kind":"text"},{"text":"config","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ExploreMoreConfig","preciseIdentifier":"s:13RevcontentSDK17ExploreMoreConfigV","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}],"roleHeading":"Instance Method","symbolKind":"method","extendedModule":"SwiftUICore","role":"symbol","externalID":"s:7SwiftUI4ViewP13RevcontentSDKE21revcontentExploreMore6configQrAD0gH6ConfigV_tF::SYNTHESIZED::s:13RevcontentSDK0A6AdViewV","modules":[{"relatedModules":["SwiftUICore"],"name":"RevcontentSDK"}]},"identifier":{"url":"doc:\/\/com.revcontent.RevcontentSDK\/documentation\/RevcontentSDK\/RevcontentAdView\/revcontentExploreMore(config:)","interfaceLanguage":"swift"},"references":{"doc://com.re